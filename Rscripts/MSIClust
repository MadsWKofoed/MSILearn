temp_imzml <- "kidney_and_tumor/RAW_tumor.imzml"


msi_data <- readImzML(temp_imzml, memory = FALSE, check = FALSE,
                      mass.range = NULL, resolution = 0.0001, units = c("mz"),
                      guess.max = 1000L, as = "auto", parse.only=FALSE,
                      verbose = getCardinalVerbose(), chunkopts = list(),
                      BPPARAM = bpparam())

control_mean <- summarizeFeatures(msi_data, "mean")



control_MSI_ref <- control_mean %>%
  peakPick(SNR = input$snr) %>%
  peakAlign(ref = mz_ref$mz, tolerance = input$tolerance, units = "mz") %>%
  subsetFeatures() %>%
  process()

msi_df <- make_msi_dataframe(msi_data)

rows_with_0 <- msi_df[apply(msi_df, 1, function(row) mean(row == 0) > 0.0001), ]

